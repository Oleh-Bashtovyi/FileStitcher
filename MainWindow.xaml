<Window x:Class="FileStitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Stitcher" Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        Background="#1A1B2E"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- ── Colours ─────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgMain"      Color="#1A1B2E"/>
        <SolidColorBrush x:Key="BgPanel"     Color="#22223B"/>
        <SolidColorBrush x:Key="BgCard"      Color="#16213E"/>
        <SolidColorBrush x:Key="BgHover"     Color="#2D2D4E"/>
        <SolidColorBrush x:Key="BgSelected"  Color="#393970"/>
        <SolidColorBrush x:Key="Accent"      Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentHover" Color="#6D28D9"/>
        <SolidColorBrush x:Key="AccentLight" Color="#A78BFA"/>
        <SolidColorBrush x:Key="TxtPrimary"  Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TxtSub"      Color="#94A3B8"/>
        <SolidColorBrush x:Key="TxtMuted"    Color="#475569"/>
        <SolidColorBrush x:Key="Border"      Color="#2D2D4E"/>
        <SolidColorBrush x:Key="Success"     Color="#10B981"/>
        <SolidColorBrush x:Key="Danger"      Color="#EF4444"/>

        <!-- ── Primary Button ────────────────────────────────────── -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"   Value="#7C3AED"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#5B21B6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#3D2066"/>
                                <Setter Property="Foreground" Value="#7C6599"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Secondary Button ──────────────────────────────────── -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="#2D2D4E"/>
            <Setter Property="Foreground"      Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3D3D5E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E1E3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Icon Button (X remove) ────────────────────────────── -->
        <Style x:Key="BtnIcon" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#64748B"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3D1515"/>
                                <Setter Property="Foreground" Value="#EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Expand/Collapse toggle for TreeView ───────────────── -->
        <Style x:Key="ExpanderToggle" TargetType="ToggleButton">
            <Setter Property="Focusable"   Value="False"/>
            <Setter Property="Width"       Value="16"/>
            <Setter Property="Height"      Value="16"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Width="16" Height="16">
                            <Path x:Name="Arrow"
                                  Data="M 3 1 L 3 11 L 11 6 Z"
                                  Fill="#64748B"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Width="7" Height="9"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="Data"  Value="M 1 3 L 11 3 L 6 11 Z"/>
                                <Setter TargetName="Arrow" Property="Fill"  Value="#A78BFA"/>
                                <Setter TargetName="Arrow" Property="Width"  Value="9"/>
                                <Setter TargetName="Arrow" Property="Height" Value="7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="#A78BFA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TreeViewItem (full dark override) ─────────────────── -->
        <Style TargetType="{x:Type TreeViewItem}">
            <Setter Property="Foreground"   Value="#E2E8F0"/>
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="IsExpanded"   Value="True"/>
            <Setter Property="Padding"      Value="2,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TreeViewItem}">
                        <StackPanel>
                            <!-- Node row -->
                            <Border x:Name="ItemBd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="5"
                                    Padding="2,1"
                                    Margin="1,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton Grid.Column="0"
                                                  x:Name="Expander"
                                                  Style="{StaticResource ExpanderToggle}"
                                                  IsChecked="{Binding IsExpanded,
                                                    RelativeSource={RelativeSource TemplatedParent},
                                                    Mode=TwoWay}"
                                                  ClickMode="Press"/>
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <!-- Children -->
                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="20,0,0,0"
                                            Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background"
                                        Value="#2D2D4E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background"
                                        Value="#393970"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TreeView itself ───────────────────────────────────── -->
        <Style TargetType="TreeView">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="4"/>
        </Style>

        <!-- ── ScrollViewer / Bar ────────────────────────────────── -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- ── CheckBox in tree ──────────────────────────────────── -->
        <Style x:Key="TreeCheckBox" TargetType="CheckBox">
            <Setter Property="Focusable"     Value="False"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"        Value="0,0,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Box"
                                Width="15" Height="15"
                                BorderBrush="#5B5B8A"
                                BorderThickness="1.5"
                                CornerRadius="3"
                                Background="#1A1B2E"
                                VerticalAlignment="Center">
                            <Grid>
                                <!-- Checkmark -->
                                <Path x:Name="Check"
                                      Data="M 2 7 L 6 11 L 13 3"
                                      Stroke="#A78BFA"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed"/>
                                <!-- Dash (indeterminate) -->
                                <Rectangle x:Name="Dash"
                                           Width="8" Height="2"
                                           Fill="#A78BFA"
                                           Visibility="Collapsed"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box"   Property="Background" Value="#3D1D8A"/>
                                <Setter TargetName="Box"   Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="{x:Null}">
                                <Setter TargetName="Dash"  Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box"   Property="Background" Value="#2D1570"/>
                                <Setter TargetName="Box"   Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#A78BFA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  ROOT GRID                                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header        -->
            <RowDefinition Height="Auto"/>   <!-- Root-folder   -->
            <RowDefinition Height="*"/>      <!-- Panels        -->
            <RowDefinition Height="Auto"/>   <!-- Footer        -->
        </Grid.RowDefinitions>

        <!-- ── HEADER ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#12122A" Padding="20,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="✂" FontSize="22" Foreground="#7C3AED"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="File Stitcher" FontSize="20" FontWeight="Bold"
                           Foreground="#E2E8F0" VerticalAlignment="Center"/>
                <TextBlock Text="   merge .cs · .json · .txt into one file"
                           FontSize="12" Foreground="#475569"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── ROOT FOLDER BAR ────────────────────────────────── -->
        <Border Grid.Row="1" Background="#12122A" Padding="20,10"
                BorderBrush="#2D2D4E" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Root:" Foreground="#64748B"
                           VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>

                <Border Grid.Column="1" Background="#1A1B2E" CornerRadius="6"
                        Padding="12,5" Margin="0,0,8,0"
                        BorderBrush="#2D2D4E" BorderThickness="1">
                    <TextBlock x:Name="TxtRootPath"
                               Text="No folder selected — click Browse to start"
                               Foreground="#475569" FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                </Border>

                <Button Grid.Column="2" Content="📁  Browse"
                        Style="{StaticResource BtnSecondary}"
                        Padding="12,6" Margin="0,0,6,0"
                        Click="BtnBrowse_Click"/>

                <Button Grid.Column="3" Content="🔄  Refresh"
                        Style="{StaticResource BtnSecondary}"
                        Padding="12,6"
                        x:Name="BtnRefresh" IsEnabled="False"
                        Click="BtnRefresh_Click"/>
            </Grid>
        </Border>

        <!-- ── MAIN PANELS ────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="14,12,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="220"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: File Browser -->
            <Border Grid.Column="0" Background="#22223B" CornerRadius="10"
                    BorderBrush="#2D2D4E" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Left header -->
                    <Border Grid.Row="0" Padding="14,10"
                            BorderBrush="#2D2D4E" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📂" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="File Browser" Foreground="#E2E8F0"
                                           FontWeight="SemiBold" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Select All"
                                    Style="{StaticResource BtnSecondary}"
                                    Padding="8,4" FontSize="11" Margin="0,0,5,0"
                                    Click="BtnSelectAll_Click"/>
                            <Button Grid.Column="2" Content="Clear All"
                                    Style="{StaticResource BtnSecondary}"
                                    Padding="8,4" FontSize="11"
                                    Click="BtnClearAll_Click"/>
                        </Grid>
                    </Border>

                    <!-- Tree -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TreeView x:Name="FileTreeView">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <CheckBox Style="{StaticResource TreeCheckBox}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  IsThreeState="False"
                                                  Click="TreeCheckBox_Click"/>
                                        <TextBlock Text="{Binding Icon}"
                                                   Foreground="#A78BFA"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,5,0"
                                                   FontSize="12"/>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#CBD5E1"
                                                   VerticalAlignment="Center"
                                                   FontSize="12.5"
                                                   ToolTip="{Binding FullPath}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>

                    <!-- Left footer -->
                    <Border Grid.Row="2" Padding="14,7"
                            BorderBrush="#2D2D4E" BorderThickness="0,1,0,0">
                        <TextBlock x:Name="TxtTreeStatus"
                                   Text="Select a root folder to begin"
                                   Foreground="#475569" FontSize="11"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="#2D2D4E" Cursor="SizeWE"/>

            <!-- RIGHT: Selected Files -->
            <Border Grid.Column="2" Background="#22223B" CornerRadius="10"
                    BorderBrush="#2D2D4E" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Right header -->
                    <Border Grid.Row="0" Padding="14,10"
                            BorderBrush="#2D2D4E" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="✅" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Selected Files" Foreground="#E2E8F0"
                                           FontWeight="SemiBold" FontSize="13"
                                           VerticalAlignment="Center"/>
                                <Border Background="#7C3AED" CornerRadius="10"
                                        Padding="7,1" Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtSelectedCount" Text="0"
                                               Foreground="White" FontSize="11"
                                               FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Remove All"
                                    Style="{StaticResource BtnSecondary}"
                                    Padding="8,4" FontSize="11"
                                    Click="BtnRemoveAll_Click"/>
                        </Grid>
                    </Border>

                    <!-- Selected list -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="8,6">
                        <ItemsControl x:Name="SelectedFilesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2" Padding="10,7"
                                            Background="#16213E"
                                            CornerRadius="7"
                                            BorderBrush="#2D2D4E"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Icon}"
                                                       Foreground="#7C3AED"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       FontSize="12"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding RelativePath}"
                                                       Foreground="#CBD5E1"
                                                       FontSize="11.5"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       ToolTip="{Binding FullPath}"/>
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource BtnIcon}"
                                                    Content="✕"
                                                    Tag="{Binding FullPath}"
                                                    Click="BtnRemoveFile_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Right footer -->
                    <Border Grid.Row="2" Padding="14,7"
                            BorderBrush="#2D2D4E" BorderThickness="0,1,0,0">
                        <TextBlock x:Name="TxtSizeInfo"
                                   Text="No files selected"
                                   Foreground="#475569" FontSize="11"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── FOOTER ──────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#12122A" Padding="20,10"
                BorderBrush="#2D2D4E" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtStatus"
                           Grid.Column="0"
                           Text="Ready"
                           Foreground="#475569"
                           VerticalAlignment="Center"
                           FontSize="12"/>

                <Button Grid.Column="1"
                        x:Name="BtnMerge"
                        Content="✂   Merge &amp; Save"
                        Style="{StaticResource BtnPrimary}"
                        Padding="22,11" FontSize="14"
                        IsEnabled="False"
                        Click="BtnMerge_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
